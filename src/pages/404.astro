---
import Layout from '@src/layouts/Layout.astro'
---

<Layout title="404 — Página no encontrada | Steve Moya" description="Esta página no existe o se movió a otro lugar.">
  <main class="flex min-h-[80vh] flex-col items-center justify-center px-6 text-center">

    <!-- Animated 404 number -->
    <div class="relative mb-8 select-none">
      <span
        class="text-[clamp(6rem,18vw,12rem)] font-black leading-none tracking-tight"
        style="
          background: linear-gradient(135deg, #ffffff 0%, #c70039 50%, #ff6b9d 100%);
          -webkit-background-clip: text;
          background-clip: text;
          -webkit-text-fill-color: transparent;
          filter: drop-shadow(0 0 60px rgba(199, 0, 57, 0.3));
        "
      >404</span>
      <!-- Decorative background blur -->
      <div class="pointer-events-none absolute inset-0 -z-10 m-auto h-full w-3/4 rounded-full bg-[#c70039] opacity-10 blur-[80px]"></div>
    </div>

    <!-- Divider line -->
    <div class="mb-8 flex items-center gap-4">
      <div class="h-px w-16 bg-gradient-to-r from-transparent to-[#c70039]/60"></div>
      <span class="h-1.5 w-1.5 rounded-full bg-[#c70039]"></span>
      <div class="h-px w-16 bg-gradient-to-l from-transparent to-[#c70039]/60"></div>
    </div>

    <h1 class="mb-4 text-2xl font-bold text-white/90 sm:text-3xl">
      Esta página se perdió en el código
    </h1>
    <p class="mb-10 max-w-md text-base text-gray-400 leading-relaxed">
      La ruta que buscas no existe, fue movida, o tal vez nunca existió.<br/>
      Aquí hay algunas opciones para retomar el camino:
    </p>

    <!-- Navigation suggestions -->
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="/"
        class="flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.04] px-5 py-3 text-sm font-semibold text-white/80 transition-all duration-300 hover:-translate-y-0.5 hover:border-[#c70039]/40 hover:bg-[#c70039]/10 hover:text-white hover:shadow-lg"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Inicio
      </a>
      <a
        href="/blog"
        class="flex items-center gap-2 rounded-xl border border-[#c70039]/30 bg-[#c70039]/10 px-5 py-3 text-sm font-semibold text-[#c70039] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#c70039]/60 hover:bg-[#c70039]/20 hover:shadow-lg"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Blog
      </a>
      <a
        href="/portafolio"
        class="flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.04] px-5 py-3 text-sm font-semibold text-white/80 transition-all duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06] hover:text-white hover:shadow-lg"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
        </svg>
        Portafolio
      </a>
    </div>

    <!-- Back link -->
    <button
      onclick="history.back()"
      class="mt-8 text-sm text-gray-500 underline underline-offset-4 transition-colors hover:text-gray-300 cursor-pointer"
    >
      ← Volver a la página anterior
    </button>
  </main>
</Layout>
