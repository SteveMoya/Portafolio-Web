---
import Layout from '@src/layouts/Layout.astro'

import { getPosts } from '@src/utils'

import ListCategories from '@components/ListCategories.astro'
import ListPosts from '@components/ListPosts.astro'
import Header from '@components/Header.astro'
import { MAX_POSTS } from '@src/consts'

const posts = await getPosts(MAX_POSTS)
---

<Layout
	title="Blog - Steve Moya Cepeda"
	description="Este en mi blog donde podrar leer, mis articulos mas destacados"
	image="images/marketing4.0-v.webp"
>
<Header title='Mis mas recientes' titleCaption='Articulos' description="Aqui puedes ver los los Articulos mas recientes de mi" descriptionCaption="Blog" />
	<ListCategories />
	<section class="max-w-screen-xl mx-auto px-4">
		<div class="flex items-center justify-between ml-4 mt-4 mb-2">
			<h2 class="md:text-start text-center text-lg font-bold tracking-wide">Los mas recientes</h2>
			<a
				href="/rss.xml"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Suscribirse via RSS"
				title="Suscribirse via RSS"
				class="flex items-center gap-2 rounded-xl border border-orange-500/30 bg-orange-500/10 px-3 py-1.5 text-xs font-semibold text-orange-400 transition-all duration-300 hover:border-orange-500/60 hover:bg-orange-500/20 hover:text-orange-300 hover:-translate-y-0.5 hover:shadow-lg"
			>
				<svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
					<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
				</svg>
				RSS
			</a>
		</div>
		<ListPosts FirstBig={true} posts={posts} />
	</section>
</Layout>