---
import Layout from './Layout.astro'
import Tag from '@components/Tag.astro'
import type { CollectionEntry } from 'astro:content'
import type { MarkdownHeading } from 'astro'
import { Picture } from 'astro:assets'

type Props = {
	id?: CollectionEntry<'blog'>['id']
	data: CollectionEntry<'blog'>['data']
	headings?: MarkdownHeading[]
}

const { title, description, pubDate, heroImage, tags, updateDate } = Astro.props.data
---

<Layout
	title={title}
	description={description}
	image={heroImage.src}
	articleDate={pubDate.toISOString()}
>
	<!-- Reading Progress Bar via slot to escape ViewTransitions animation root -->
	<div slot="header-progress" class="fixed top-0 left-0 z-[9999] h-[2px] w-full origin-left bg-[#c70039] animate-reading-progress mt-16 sm:mt-0 shadow-[0_0_10px_rgba(199,0,57,0.5)]"></div>

	<section
		class="mt-4 grid gap-12 overflow-hidden px-5 antialiased sm:mx-auto sm:max-w-2xl sm:px-8 md:max-w-6xl md:overflow-visible lg:px-0"
		data-pagefind-body
	>
		<article class="min-w-full sm:max-w-none md:max-w-none md:py-4">
			<header class="mb-8 flex flex-col items-start justify-center gap-6 md:mb-10">
				<div class="flex flex-col gap-4">
					<div class="flex items-center gap-4 text-sm tracking-wide text-gray-400">
						<p>
							{
								pubDate.toLocaleDateString('es-Es', {
									year: 'numeric',
									month: 'long',
									day: 'numeric'
								})
							}
						</p>
						{
							updateDate && (
								<>
									<span class="h-1 w-1 rounded-full bg-gray-600"></span>
									<p>
										Actualizado el{' '}
										{new Date(updateDate).toLocaleDateString('es-Es', {
											year: 'numeric',
											month: 'long',
											day: 'numeric'
										})}
									</p>
								</>
							)
						}
					</div>
					<h1 class="text-left text-4xl font-bold leading-tight tracking-tight capitalize text-white md:text-5xl lg:text-5xl lg:leading-[1.1]">
						{title}
					</h1>
				</div>

				<div class="flex flex-wrap items-center justify-start gap-3 mt-2">
					{tags.map((tag) => <Tag tag={tag} />)}
				</div>
			</header>

			{
				heroImage && (
					<div class="relative w-full overflow-hidden rounded-2xl border border-white/5 my-8 shadow-xl shadow-black/50">
						<Picture
							src={heroImage}
							width={1200}
							height={675}
							loading="eager"
							class="w-full aspect-video md:aspect-[21/9] object-cover"
							alt={`Imagen de ${title}`}
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
					</div>
				)
			}

			<hr />

			<div>
				<slot />
			</div>
		</article>
	</section>
</Layout>
<script>
	const fnObserver = () => {
		function handleIntersection(
			entries: IntersectionObserverEntry[],
			_observer: IntersectionObserver
		) {
			entries.forEach((entry) => {
				const index = document.querySelector(`aside a[href="#${entry.target.id}"]`)

				if (entry.isIntersecting) {
					index?.classList.remove('text-gray-500', 'border-transparent') // remove normal
					index?.classList.add(
						'text-white',
						'border-[#c70039]',
						'font-medium'
					)
				} else {
					index?.classList.add('text-gray-500', 'border-transparent') // add normal
					index?.classList.remove(
						'text-white',
						'border-[#c70039]',
						'font-medium'
					)
				}
			})
		}

		const headings = document.querySelectorAll(
			'div.prose h1, div.prose h2, div.prose h3, div.prose h4, div.prose h5, div.prose h6'
		)

		const options = {
			root: null,
			rootMargin: ' 15% 0px 0% 0px ',
			threshold: 1
		}

		const observer = new IntersectionObserver(handleIntersection, options)

		headings.forEach((heading) => {
			observer.observe(heading)
		})
	}
	fnObserver()
	document.addEventListener('astro:after-swap', fnObserver)
</script>

<style is:global>
	@keyframes reading-progress {
		0% { transform: scaleX(0); }
		100% { transform: scaleX(1); }
	}
	.animate-reading-progress {
		animation: reading-progress linear;
		animation-timeline: scroll(root block);
	}
</style>
