---
import { siteConfig } from '@src/data/config'
import { ViewTransitions } from 'astro:transitions'

interface Props {
	title?: string
	description?: string
	image?: string
	articleDate?: string | undefined
	articleUpdateDate?: string | undefined
	keywords?: string
	canonicalURL?: string | URL
}

const {
	title = siteConfig.title,
	description = siteConfig.description,
	keywords = siteConfig.keywords,
	canonicalURL = new URL(Astro.url.pathname, Astro.site) || 'https://stevemoya.me/',
	image = siteConfig.ogImage,
	articleDate,
	articleUpdateDate
} = Astro.props

// Ensure absolute URL for OG Images
const ogImageUrl = new URL(image, Astro.site || 'https://stevemoya.me').toString()

// Dynamic Schema.org JSON-LD
const schema = {
	"@context": "https://schema.org",
	"@type": articleDate ? "BlogPosting" : "Person",
	...(articleDate
		? {
				headline: title,
				description: description,
				image: [ogImageUrl],
				url: canonicalURL.toString(),
				datePublished: articleDate,
				...(articleUpdateDate ? { dateModified: articleUpdateDate } : {}),
				author: {
					"@type": "Person",
					name: siteConfig.author,
					url: Astro.site || 'https://stevemoya.me'
				}
		  }
		: {
				name: siteConfig.author,
				url: Astro.site || 'https://stevemoya.me',
				jobTitle: "Marketer & Desarrollador Web",
				description: siteConfig.description,
				image: ogImageUrl
		  }
	)
}
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<ViewTransitions />

<!-- Title: Recommended: 60 characters -->
<title>{title}</title>
<!--favicon-img-->
<link title="logo" rel="icon" type="image/png" href={siteConfig.favicon} />
<link rel="shortcut icon" href={siteConfig.favicon} type="image/x-icon" />
<!-- Description: Recommended: 155 - 160 characters -->
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={siteConfig.author} />

<!-- Google / Search Engine Tags -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:locale" content={siteConfig.ogLocale || 'es_DO'} />
<meta property="og:logo" content={siteConfig.favicon} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />

<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />

{
	articleDate && (
		<>
			<meta property="article:author" content={siteConfig.author} />
			<meta property="article:published_time" content={articleDate} />
		</>
	)
}

<!-- RSS auto-discovery -->
<link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/rss.xml" />

<!-- Schema.org Script -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<meta name="robots" content="index, follow" />
<meta property="og:type" content={articleDate ? "article" : "website"} />
