---
import { getCategories } from "@src/utils"
import Category from "./Category.astro"


const categories = await getCategories()

const { activeCategory } = Astro.props

---

<div class='flex flex-wrap max-w-screen-xl mx-auto px-4 gap-3 justify-center mb-12 mt-4'>
	<Category />
	{
		categories.map((category: string) => (
			<Category name={category} activeCategory={activeCategory} />
		))
	}
</div>
