---
import { Image } from 'astro:assets'
import FormattedDate from './ui/FormattedDate.astro'

const {
	data: { title, description, pubDate, heroImage, category },
	slug,
	isFeatured = false
} = Astro.props
---

<article
	class={`group relative flex h-full overflow-hidden rounded-2xl border border-white/5 bg-black/20 backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:border-[#c70039]/40 hover:bg-black/40 hover:shadow-[0_12px_40px_rgba(199,0,57,0.18)] ${isFeatured ? 'flex-col md:flex-row md:col-span-2 shadow-2xl shadow-black/50' : 'flex-col shadow-lg shadow-black/20'}`}
>
	<a class={`relative block overflow-hidden ${isFeatured ? 'w-full md:w-1/2 aspect-[16/9] md:aspect-auto' : 'w-full aspect-[16/9]'}`} href={`/blog/${slug}/`} title={`Ver ${title}`}>
		<Image
			src={heroImage}
			width={600}
			height={337}
			format="webp"
			class="h-full w-full object-cover object-center transition-transform duration-700 ease-in-out group-hover:scale-105"
			alt={`Imagen de ${title}`}
		/>
		
		{/* Gradiente inferior para mejorar legibilidad sobre la imagen */}
		<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 transition-opacity duration-500 group-hover:opacity-100"></div>

		{/* Badges superiores (Categoría) */}
		<div class="absolute top-4 left-4 right-4 flex items-start justify-between z-10">
			<span
				class="rounded-full bg-black/40 backdrop-blur-md border border-white/10 px-3 py-1 text-xs font-semibold tracking-wide text-white transition-colors duration-300 group-hover:border-white/30"
			>
				{category}
			</span>
		</div>
	</a>

	<div class={`flex flex-col flex-grow z-10 relative ${isFeatured ? 'p-8 md:p-12 md:w-1/2 md:justify-center' : 'p-6 md:p-8'}`}>
		{/* Fondo sutil con glassmorphism en el contenido */}
		<div class="absolute inset-0 -z-10 bg-gradient-to-br from-transparent via-transparent to-white/[0.02] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

		<div class="mb-4 flex items-center text-sm text-gray-500 font-medium tracking-wide">
			<svg class="mr-2 h-4 w-4 transition-colors duration-300 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
			</svg>
			<span class="transition-colors duration-300 group-hover:text-gray-300">
				<FormattedDate date={pubDate} />
			</span>
		</div>

		<a class="block outline-none" href={`/blog/${slug}/`}>
			<h3 class={`mb-4 font-bold leading-tight text-white transition-colors duration-300 ease-in-out group-hover:text-[#c70039] line-clamp-2 ${isFeatured ? 'text-2xl md:text-3xl lg:text-4xl' : 'text-xl md:text-2xl'}`}>
				{title}
			</h3>
		</a>

		<p class={`text-gray-400 font-light leading-relaxed line-clamp-3 mb-6 flex-grow transition-colors duration-300 group-hover:text-gray-300 ${isFeatured ? 'text-base md:text-lg' : 'text-sm md:text-base'}`}>
			{description}
		</p>
		
		<div class="mt-auto pt-5 border-t border-white/5 transition-colors duration-300 group-hover:border-white/10">
			<a 
				href={`/blog/${slug}/`}
				class="inline-flex items-center text-sm font-semibold tracking-wide text-white/50 transition-colors duration-300 group-hover:text-white"
			>
				Leer artículo
				<svg class="ml-2 h-4 w-4 transform transition-all duration-300 group-hover:translate-x-2 group-hover:text-[#c70039]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
				</svg>
			</a>
		</div>
	</div>
</article>
