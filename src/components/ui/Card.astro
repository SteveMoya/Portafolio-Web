---

import Button from './Button.astro'

// import { twMerge } from 'tailwind-merge'
import { CldImage } from 'astro-cloudinary'


interface Props {
	class?: string
	type?: 'about'
	title?: string
	img?: any
	description?: string
	href?: string
	date?: string
}

const { type, title, img = '', description, href, date } = Astro.props
---

{
	type === 'about' && (
		<article class="group relative m-4 w-full max-w-[350px] md:m-3 lg:w-[calc(33.333%-2rem)] cursor-pointer">
			{/* Efecto de Cartas Apiladas (Background Cards) - Hacia abajo, color principal con borde más claro para contraste y menor opacidad */}
			{/* Carta 3 (Más profunda/lejana) */}
			<div class="absolute inset-0 rounded-2xl bg-[#c70039] border border-white/5 z-0 transition-all duration-700 ease-out opacity-0 lg:group-hover:opacity-10 lg:group-hover:-translate-x-4 lg:group-hover:translate-y-4 lg:group-hover:rotate-[-3deg] lg:group-hover:delay-200"></div>
			
			{/* Carta 2 (Intermedia) */}
			<div class="absolute inset-0 rounded-2xl bg-[#c70039] border border-white/10 z-0 transition-all duration-500 ease-out opacity-0 lg:group-hover:opacity-20 lg:group-hover:-translate-x-3 lg:group-hover:translate-y-3 lg:group-hover:rotate-[-2deg] lg:group-hover:delay-200"></div>
			
			{/* Carta 1 (Más cercana a la principal) */}
			<div class="absolute inset-0 rounded-2xl bg-[#c70039] border border-white/20 z-0 transition-all duration-300 ease-out opacity-0 lg:group-hover:opacity-40 lg:group-hover:-translate-x-2 lg:group-hover:translate-y-2 lg:group-hover:rotate-[-1deg] lg:group-hover:delay-200"></div>

			{/* Contenedor Principal de la Tarjeta */}
			<div class="relative z-10 flex flex-col items-center overflow-hidden rounded-2xl border border-white/10 bg-white/5 p-8 text-center backdrop-blur-md transition-all duration-200 hover:-translate-y-2 hover:border-[#c70039]/80 group-hover:bg-[#050505] hover:shadow-[0_8px_30px_rgb(199,0,57,0.4)] h-full">
				<div class="relative mb-6 flex h-24 w-24 items-center justify-center rounded-2xl bg-gradient-to-br from-[#c70039]/20 to-transparent p-4 shadow-inner ring-1 ring-white/10 transition-all duration-500 group-hover:scale-110 group-hover:from-[#c70039]/40 group-hover:ring-[#c70039]/50">
					<img
						title={title}
						class="relative z-10 h-full w-full object-contain drop-shadow-md transition-transform duration-500 group-hover:rotate-6 group-hover:scale-110"
						loading="lazy"
						src={img}
						alt={`${title} logo`}
					/>
					<div class="absolute inset-0 z-0 rounded-2xl bg-[#c70039] opacity-0 blur-xl transition-opacity duration-500 group-hover:opacity-30"></div>
				</div>
				<h2 class="mb-4 text-2xl font-bold tracking-wide text-white transition-colors duration-300 group-hover:text-[#c70039]">{title}</h2>
				<p class="text-sm leading-relaxed text-gray-300 opacity-90">{description}</p>
			</div>
		</article>
	)
}

