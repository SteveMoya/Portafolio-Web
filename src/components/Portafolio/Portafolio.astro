---
import PortafolioCard from '@components/PortafolioCard.astro'
import { getEntry } from 'astro:content'

const marketingimg = await getEntry('portafolio', 'portafolio/rmfvigaluuqqsybglhbd')

const webimg = await getEntry('portafolio', 'portafolio/izqsfrsjivj4qljolhfj')

const fotografiaimg = await getEntry('portafolio', 'portafolio/ekshqf7dkcemzrhcvsvv')

const disenoimg = await getEntry('portafolio', 'portafolio/zw2fdggeox7wjw3tmxov')


const portafolios = [
	{
		title: 'Marketing',
		img: marketingimg?.data.public_id,
		description: 'Aqui todas mis estrategias de marketing y proyectos realizados',
		href: '/blog/category/marketing/1'
	},
	{
		title: 'Fotografía',
		img: fotografiaimg?.data.public_id,
		description: 'Aqui todas mis sesiones de fotos y proyectos fotográficos',
		href: '/portafolio/fotografia'
	},
	{
		title: 'Web',
		img: webimg?.data.public_id,
		description: 'Aqui todas mis páginas web',
		href: '/portafolio/webs'
	},
	{
		title: 'Diseño Gráfico',
		img: disenoimg?.data.public_id,
		description: 'Aqui todos mis diseños gráficos donde deje libre mi creatividad',
		href: '/portafolio/diseno'
	}
]
---

<section class="grid grid-cols-1 md:grid-cols-2 gap-6 p-4 md:p-8 max-w-[1280px] mx-auto w-full">
	{portafolios.map((portafolio) => <PortafolioCard {...portafolio} />)}
</section>
