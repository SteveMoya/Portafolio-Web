---
const { page } = Astro.props
---

<div class="flex items-center justify-between gap-5 p-2 md:gap-1 mt-10 border-t border-white/5 pt-8">
	<!-- Previous Button -->
	{
		page.start > 0 ? (
			<a
				href={page.url.prev}
				class={`flex h-10 items-center justify-center rounded-xl bg-transparent px-4 text-sm font-medium text-white/70 transition-colors hover:text-white hover:bg-white/5`}
				title="Página anterior"
			>
				<svg class="mr-2 h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				Anterior
			</a>
		) : (
			<span class="flex h-10 cursor-not-allowed items-center justify-center rounded-xl bg-transparent px-4 text-sm font-medium text-white/30">
				<svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
				</svg>
				Anterior
			</span>
		)
	}

	<!-- Page Numbers -->
	<ul class="flex items-center gap-x-1">
		{
			Array.from({ length: page.lastPage }).map((_, index) => (
				<li>
					{
						page.currentPage === index + 1 ? (
							<span class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white shadow-[0_0_15px_rgba(255,255,255,0.05)]">
								{index + 1}
							</span>
						) : (
							<a
								href={`${index + 1}`}
								class="flex h-10 w-10 items-center justify-center rounded-full bg-transparent text-sm font-medium text-white/50 transition-colors hover:bg-white/5 hover:text-white"
							>
								{index + 1}
							</a>
						)
					}
				</li>
			))
		}
	</ul>

	<!-- Next Button -->
	{
		page.currentPage < page.lastPage ? (
			<a
				href={page.url.next}
				class="group flex h-10 items-center justify-center rounded-xl bg-transparent px-4 text-sm font-medium text-white/70 transition-colors hover:text-white hover:bg-white/5"
			>
				Siguiente
				<svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l7-7m-7 7h18"></path>
				</svg>
			</a>
		) : (
			<span class="flex h-10 cursor-not-allowed items-center justify-center rounded-xl bg-transparent px-4 text-sm font-medium text-white/30">
				Siguiente
				<svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l7-7m-7 7h18"></path>
				</svg>
			</span>
		)
	}
</div>
